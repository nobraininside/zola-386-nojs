# =============================================================================
# SITE CONFIGURATION
# PUT THIS FILE AT THE ROOT OF YOUR ZOLA WEBSITE
# RENAME IT config.toml AND FILL IT
# =============================================================================

# The root URL of your site. Used to generate absolute links and RSS feeds.
base_url = "<YOUR_URL_(beginning_with_https://)>"

# UNCOMMENT TO ENABLE THE THEME
theme = "zola-386-nojs"

default_language = "en"
title = "<YOUR_URL_(without_https://)_OR_YOUR_WEBSITE'S_NAME>"
description = "<YOUR_MOTTO_(will_appear_in_homepage_header)>"

# Enable SASS compilation for the DOS-minimalist theme
compile_sass = true

# Search index is disabled to maximize privacy and speed
build_search_index = false

# Taxonomies configuration
taxonomies = [
  {name="categories", rss=true},
  {name="tags", rss=true},
]

# =============================================================================
# THEME EXTRA PARAMETERS
# =============================================================================

# Footer content
[extra]
year = "2026"
author = "<YOUR_NAME>"
author_url = "<LINK_YOUR_NAME_TO_ANOTHER_WEBSITE>"
social = "<YOUR_REFERRED_SOCIAL>"
social_url = "<LINK_TO_YOUR_SOCIAL_PERSONAL_PAGE>"
vat = "<YOUR_VAT_NUMBER>"

keywords = "zola, theme, retro, hacking"
theme_color = "#000084"

# Navigation menu structure
zola386_menu = [
  {path="", name="Home"},
  {path="categories", name="Categories"},
  {path="tags", name="Tags"},
  {path="about", name="About"},
]

# =============================================================================
# SOCIAL & METADATA
# =============================================================================

linkedin_user = "<YOUR_LINKEDIN_USER_PAGE>"
github_user = "YOUR_GITHUB_USERNAME>"

# UI Labels (Internationalization)
label_tags = "Tags"
label_tag = "Tag"
label_categories = "Categories"
label_category = "Category"
label_author = "Author"
label_date = "Date"
label_taxonomy = "Taxonomy"
label_reading = "Reading time"
label_read_more = "Read more"